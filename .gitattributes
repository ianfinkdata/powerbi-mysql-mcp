# Auto-detect text files and normalize line endings to LF in the repo.
# Checked out as native line endings on each OS.
* text=auto eol=lf

# Explicit text types
*.sql   text eol=lf
*.md    text eol=lf
*.csv   text eol=lf
*.txt   text eol=lf
*.json  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.py    text eol=lf
.gitattributes text eol=lf
.gitignore     text eol=lf
LICENSE        text eol=lf

# Binary types (never touch)
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.pdf   binary
*.xlsx  binary
*.xls   binary
*.zip   binary
*.gz    binary
*.ico   binary